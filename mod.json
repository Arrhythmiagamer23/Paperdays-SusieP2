{
	"geode": "4.10.0",
	"early-load": true,
	"gd": {
		"win": "2.2074",
		"android": "2.2074"
	},
	"id": "lil2kki.paperdays",
	"name": "\tPaperdays",
	"version": "v2.5.5",
	"developers": [ "lil2kki" ],
	"description": "geometry dash fanmade extension but its looks like horror game made in rpg maker",
	"tags": [ "interface", "offline", "gameplay", "content" ],
	"links": {
		"community": "https://discord.gg/kXjQ8QEWNU",
		"homepage": "https://t.me/lil2kki_ch",
		"source": "https://github.com/lil2kki/Paperdays"
	},
	"dependencies": {
		"geode.node-ids": {
			"version": ">=v1.13.1",
			"importance": "suggested"
		}
	},
	"resources": {
		"fonts": {
			"bigFont": {
				"path": "assets/_handwr.otf",
				"size": 82
			},
			"goldFont": {
				"path": "assets/_handwr.otf",
				"size": 72
			},
			"gjFont01": {
				"path": "assets////aTravelingTypewriter.ttf",
				"size": 92
			},
			"chatFont": {
				"path": "assets/aTravelingTypewriter.ttf",
				"size": 58
			},
			"GhastlyPanicCyr": {
				"path": "assets/GhastlyPanicCyr.otf",
				"size": 74
			}
		},
		"files": [
			"assets/files/**/*.*"
		],
		"sprites": [
			"assets/sprites/**/*.png"
		],
		"spritesheets": {
			"spritesheet": [
				"assets/frames/**/*.png"
			]
		}
	},
	"api": {
		"include": [
			"resources/**/*.*"
		]
	}
}
